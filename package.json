{
  "name": "leclerc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:complete": "bash scripts/dev-complete.sh",
    "qvac": "bash infra/qvac/start-local.sh",
    "qvac:ngrok": "bash scripts/qvac-ngrok.sh",
    "dev:qvac": "bash scripts/dev-qvac.sh",
    "voice": "bun --filter voice start",
    "voice:smoke": "bun --filter voice smoke",
    "qvac:artifacts": "bun scripts/qvac-artifacts.mjs",
    "wallet:smoke": "bun scripts/wallet-smoke.mjs",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "turbo": "^2.5.8",
    "typescript": "^5"
  }
}
