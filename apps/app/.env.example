# ── QVAC (OpenAI-compatible station server) ────────────────────────────────
NEXT_PUBLIC_QVAC_LOCAL_URL=http://localhost:11434
NEXT_PUBLIC_QVAC_LOCAL_KEY=
NEXT_PUBLIC_QVAC_ASR_MODEL=whisper-base
NEXT_PUBLIC_QVAC_REMOTE_LLM=qwen3-1.7b
NEXT_PUBLIC_QVAC_ASR_LANG=es
QVAC_PORT=11434

# ── Voice service (continuous-VAD WS, services/voice) ──────────────────────
NEXT_PUBLIC_VOICE_WS_URL=ws://localhost:7077

# ── QVAC P2P (Holepunch delegated inference) ───────────────────────────────
# 64-hex seed controlling the station's stable peer identity. KEEP SECRET.
QVAC_HYPERSWARM_SEED=
# The station peer public key a thin/mobile client delegates to.
STATION_PEER_PUBKEY=

# ── RAG ────────────────────────────────────────────────────────────────────
LECLERC_RAG_WORKSPACE=dossier
# Embedding model defaults to the bundled EMBEDDINGGEMMA_300M_Q8_0. Override with
# a registry:// key or file path only to use a different one.
LECLERC_EMBED_SRC=
# Optional MedPsy (Our Psy track): registry:// key or file path to MedPsy GGUF.
LECLERC_MEDPSY_SRC=
# Optional document-intel / translate model srcs (not on the core path):
LECLERC_OCR_SRC=
LECLERC_TRANSLATE_SRC=

# ── Wallet (Tether WDK) — NEVER commit a real seed ─────────────────────────
WDK_INDEXER_BASE_URL=https://wdk-api.tether.io
WDK_INDEXER_API_KEY=
EVM_RPC_URL=
EVM_CHAIN_ID=11155111
# Testnet token contract in base units. Required for EVM transfers/balances.
# Never use Ethereum mainnet USDT here.
USDT_ADDRESS=
# Spark/Lightning network. LeClerc demo runtime enforces TESTNET.
SPARK_NETWORK=TESTNET
LN_MAX_FEE_SATS=50
# Optional smoke-only BOLT11 invoice. If absent, wallet smoke records SKIPPED.
LECLERC_TESTNET_LIGHTNING_INVOICE=
# Set to 1 to exercise live Spark address/balance without a payment invoice.
LECLERC_ENABLE_LIVE_SPARK_SMOKE=
# SEED_PHRASE is supplied at runtime (encrypted/secure storage), not here.

# ── Compliance switch (must stay false for judged builds) ──────────────────
LECLERC_ALLOW_NONQVAC=false
