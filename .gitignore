# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any workspace)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js (any workspace)
.next/
out/

# turborepo
.turbo/

# local on-device report store
.data/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.claude
.gstack/

# codex CLI config (contains API keys — keep local)
.codex/

# local env
.env*.local
